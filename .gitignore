# ==========================================
# 1. 核心大文件与外部依赖 (防 Git 仓库撑爆)
# ==========================================
# 屏蔽所有的 Windows 可执行文件 (ffmpeg, ffprobe, fpcalc 等)
*.exe
# 屏蔽本地 AI 模型权重文件夹
models/

# ==========================================
# 2. 数据库与用户本地工作区 (防隐私泄露)
# ==========================================
# 屏蔽所有的 SQLite 数据库文件
*.db
*.sqlite
*.sqlite3
# 屏蔽用户建立的多任务工作区与历史记录
workspaces/
# 屏蔽可能生成在外的 ASR 导出台词结果
asr_texts/

experiments/

# ==========================================
# 3. Python 运行与编译缓存
# ==========================================
__pycache__/
*.py[cod]
*$py.class
# 如果你以后用虚拟环境开发，屏蔽虚拟环境目录
venv/
env/
.venv/

# ==========================================
# 4. PyInstaller 打包生成的目录
# ==========================================
# 忽略 PyInstaller 临时编译目录和最终输出目录
build/
dist/
# 忽略打包生成的缓存和 spec 配置文件
*.manifest
# 注意：屏蔽所有 spec，但保留你的主构建文件
*.spec
!build_all.spec

# ==========================================
# 5. 临时文件与日志
# ==========================================
# 屏蔽运行过程中的报错日志或移动日志
*.log
# 屏蔽脚本执行中产生的临时音视频切片 (如 _temp_audio.wav)
*.wav
*.mp3
*.jpg
*.tmp

# ==========================================
# 6. 操作系统与编辑器缓存 (保持项目纯净)
# ==========================================
# VSCode 配置文件
.vscode/
# PyCharm 配置文件
.idea/
# Windows 缩略图缓存
Thumbs.db
# macOS 系统文件
.DS_Store